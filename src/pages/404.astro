---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - 页面未找到">
  <div class="flex flex-col items-center justify-center px-4 py-20 text-center md:py-28">
    <h1 class="text-8xl font-bold text-neutral-200 dark:text-neutral-700 md:text-9xl">404</h1>
    <h2 class="mt-6 text-2xl font-bold text-neutral-900 dark:text-neutral-100">页面未找到</h2>
    <p class="mt-3 text-neutral-600 dark:text-neutral-300">
      你访问的页面不存在或已被移动。
    </p>
    <a
      href="/"
      class="mt-8 inline-flex items-center justify-center rounded-md bg-blue-600 px-6 py-3 text-sm font-medium text-white transition-colors hover:bg-blue-700 dark:bg-blue-600 dark:hover:bg-blue-500"
    >
      返回首页
    </a>
  </div>
</Layout>
