---
import Layout from '../layouts/Layout.astro';
import { site } from '../config';
import Icon from '../components/Icon.astro';
import Giscus from '../components/Giscus.astro';

const { author, socialLinks } = site;
---

<Layout title="关于">
  <div class="max-w-4xl mx-auto px-4 py-8">
    <div class="flex flex-col md:flex-row gap-8">
      <!-- 左侧个人信息 -->
      <div class="md:w-1/3 text-center mb-8 md:mb-0">
        <div class="sticky top-20">
          <img
            src={site.avatar}
            alt={author}
            class="w-32 h-32 rounded-full mx-auto mb-6"
          />
          <h1 class="text-3xl font-bold mb-4 text-black dark:text-gray-200">
            {author}
          </h1>
          <div class="flex space-x-4 mt-6 justify-center">
            {
              socialLinks.map(link => (
                <a
                  href={link.link}
                  class="text-gray-600 hover:text-gray-900 dark:text-gray-300 dark:hover:text-gray-200"
                  target={link.target || '_blank'}
                  rel="noopener noreferrer"
                >
                  <span class="sr-only">{link.icon}</span>
                  <Icon name={link.icon} fontSize="24px" />
                </a>
              ))
            }
          </div>
        </div>
      </div>

      <!-- 右侧内容 -->
      <div class="md:w-2/3">
        <div class="prose dark:prose-invert max-w-none">
          <div
            class="bg-green-50 dark:bg-green-900/20 p-4 rounded-md border-l-4 border-green-500 mb-8"
          >
            <p class="text-green-800 dark:text-green-300 m-0">
              有人去餐厅点了鸽子汤，汤里面没有鸽子。但是他说这个汤很正宗，噢？
            </p>
          </div>

          <h2 class="text-black dark:text-gray-200">简介</h2>
          <p>嗨～我是陈同学，一个充满好奇心的前端选手</p>
          <p>在往全栈开发方向发展，希望利用 AI 创造更多有意思的产品</p>
          <p>业余时间偶尔搞点代码玩具、搞搞服务器、折腾开源～</p>

          <h2 class="text-black dark:text-gray-200">个人经历</h2>
          <ul>
            <li>广东工业大学 • 计算机科学与技术</li>
            <li>
              广工 • 编程练习平台 <a
                href="https://anyview.gdut.edu.cn/"
                target="_blank"
                rel="noopener">Anyview</a
              >
            </li>
            <li>
              深圳 • 字节跳动 • <a
                href="https://www.feishu.cn/product/docs"
                target="_blank"
                rel="noopener">飞书文档</a
              >
              • 中台
              <ul>
                <li>接入基础组件库 Universal Design</li>
                <li>业务组件库 Monorepo 搭建</li>
                <li>增长业务支持，迁移平台和工具维护</li>
              </ul>
            </li>
            <li>
              深圳 • 字节跳动 • <a
                href="https://www.feishu.cn/product/docs"
                target="_blank"
                rel="noopener">飞书文档</a
              >
              • Doc
              <ul>
                <li>文档质量建设，自动化测试流程搭建</li>
                <li>文档研发效能，持续集成流水线优化</li>
                <li>文档开放能力，文档小组件开发</li>
                <li>文档 AIGC 开发</li>
              </ul>
            </li>
            <li>
              北京 • 即时设计 • <a
                href="https://wegic.ai/"
                target="_blank"
                rel="noopener">Wegic.ai</a
              >
              <ul>
                <li>AI 业务 x 前端工程 x 全栈开发</li>
              </ul>
            </li>
          </ul>

          <h2 class="text-black dark:text-gray-200">联系我</h2>
          <p>欢迎交流前端技术、产品设计或开源项目～ 如有侵权问题，请联系删除</p>

          <ul>
            <li>
              Github: <a
                href="https://github.com/ischanx"
                target="_blank"
                rel="noopener">https://github.com/ischanx</a
              >
            </li>
            <li>
              Email: <a href="mailto:ischanx@foxmail.com">ischanx@foxmail.com</a
              >
            </li>
          </ul>
        </div>

        <div class="mt-8">
          <Giscus />
        </div>
      </div>
    </div>
  </div>
</Layout>
