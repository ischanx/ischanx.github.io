---
import 'viewerjs/dist/viewer.css';
import ScrollArea from './ScrollArea.astro';
---

<div
  id="article-content"
  class="article-prose prose dark:prose-invert max-w-none rounded-lg animate-slide-up pt-3 pb-6 md:pt-4 md:pb-10"
  style="animation-delay: 300ms;"
>
  <slot />
</div>

<ScrollArea class="hidden" />

<style>
  @reference "../styles/global.css";

  :global(.article-prose) {
    --article-dark-text: #b8bec8;
    @apply text-base;
    color: rgb(17 24 39);
    font-family: var(--font-article);
    font-kerning: normal;
    font-variant-ligatures: common-ligatures;
    font-weight: 400;
    letter-spacing: 0.005em;
    line-height: 1.88;
    overflow-wrap: break-word;
    text-rendering: optimizeLegibility;

    :global(.dark) & {
      color: var(--article-dark-text);
    }

    p {
      @apply my-4 md:my-5;
      line-height: 1.88;
      text-align: justify;
      text-wrap: pretty;
      hanging-punctuation: first allow-end;
    }

    hr {
      @apply my-8 md:my-10 border-0;
    }

    h1,
    h2,
    h3,
    h4,
    h5,
    h6 {
      font-family: var(--font-article-heading);
      color: rgb(15 23 42);
      letter-spacing: 0;
      scroll-margin-top: 5rem;
      text-wrap: balance;

      :global(.dark) & {
        color: rgb(209 213 219);
      }
    }

    h1 {
      @apply text-xl md:text-[1.75rem] font-bold mb-3 md:mb-4 mt-9 md:mt-11;
      line-height: 1.3;
    }
    h2 {
      @apply text-xl md:text-[1.625rem] font-bold mb-3 md:mb-4 mt-8 md:mt-10;
      line-height: 1.3;
    }
    h3 {
      @apply text-lg md:text-[1.375rem] font-bold mb-2 md:mb-3 mt-6 md:mt-8;
      line-height: 1.35;
    }
    h4 {
      @apply text-base md:text-lg font-semibold mb-2 mt-5 md:mt-6;
      line-height: 1.45;
    }
    h5 {
      @apply text-sm md:text-base font-semibold mb-2 mt-4 md:mt-5;
      color: rgb(55 65 81);
      line-height: 1.5;

      :global(.dark) & {
        color: rgb(209 213 219);
      }
    }
    h6 {
      @apply text-xs md:text-sm font-semibold mb-2 mt-4;
      color: rgb(75 85 99);
      letter-spacing: 0.02em;
      line-height: 1.5;

      :global(.dark) & {
        color: rgb(156 163 175);
      }
    }

    h1 > a[href^='#'],
    h2 > a[href^='#'],
    h3 > a[href^='#'],
    h4 > a[href^='#'],
    h5 > a[href^='#'],
    h6 > a[href^='#'] {
      @apply ml-2 inline-flex h-4 w-4 items-center justify-center text-gray-400 no-underline opacity-0 transition-opacity duration-200 hover:text-primary-600 focus-visible:text-primary-600 focus-visible:opacity-100 focus-visible:outline-none dark:text-gray-600 dark:hover:text-primary-400 dark:focus-visible:text-primary-400;
      line-height: 1;
      vertical-align: 0.01em;
    }

    h1:hover > a[href^='#'],
    h1:focus-within > a[href^='#'],
    h2:hover > a[href^='#'],
    h2:focus-within > a[href^='#'],
    h3:hover > a[href^='#'],
    h3:focus-within > a[href^='#'],
    h4:hover > a[href^='#'],
    h4:focus-within > a[href^='#'],
    h5:hover > a[href^='#'],
    h5:focus-within > a[href^='#'],
    h6:hover > a[href^='#'],
    h6:focus-within > a[href^='#'] {
      @apply opacity-100;
    }

    h1 > a[href^='#'] .icon-link,
    h2 > a[href^='#'] .icon-link,
    h3 > a[href^='#'] .icon-link,
    h4 > a[href^='#'] .icon-link,
    h5 > a[href^='#'] .icon-link,
    h6 > a[href^='#'] .icon-link {
      @apply flex h-full w-full items-center justify-center;
      line-height: 1;
    }

    h1 > a[href^='#'] .icon-link::before,
    h2 > a[href^='#'] .icon-link::before,
    h3 > a[href^='#'] .icon-link::before,
    h4 > a[href^='#'] .icon-link::before,
    h5 > a[href^='#'] .icon-link::before,
    h6 > a[href^='#'] .icon-link::before {
      content: '#';
      display: block;
      line-height: 1;
      transform: translateY(-0.03em);
    }

    strong,
    b {
      color: inherit;
      font-weight: 700;
    }

    ul,
    ol {
      @apply my-4 md:my-5;
    }

    li {
      @apply my-1.5;
      line-height: 1.8;
    }

    blockquote {
      @apply my-5 md:my-6 py-1;
      font-style: normal;
      line-height: 1.86;
    }

    .color-block {
      --callout-color: 59 130 246;
      @apply my-5 md:my-6 rounded-lg border px-4 py-3 text-sm md:text-[15px] text-gray-800 shadow-sm dark:text-gray-200;
      background:
        linear-gradient(
          90deg,
          rgb(var(--callout-color) / 0.16),
          rgb(var(--callout-color) / 0.06)
        ),
        rgb(255 255 255 / 0.72);
      border-color: rgb(var(--callout-color) / 0.32);
      box-shadow: inset 4px 0 0 rgb(var(--callout-color) / 0.82);
      line-height: 1.8;
    }

    .color-block > :first-child {
      @apply mt-0;
    }

    .color-block > :last-child {
      @apply mb-0;
    }

    .color-block a {
      color: rgb(var(--callout-color));
    }

    .color-block code {
      background-color: rgb(var(--callout-color) / 0.12);
    }

    .color-block--slate {
      --callout-color: 100 116 139;
    }

    .color-block--zinc {
      --callout-color: 113 113 122;
    }

    .color-block--neutral {
      --callout-color: 115 115 115;
    }

    .color-block--stone {
      --callout-color: 120 113 108;
    }

    .color-block--red {
      --callout-color: 239 68 68;
    }

    .color-block--orange {
      --callout-color: 249 115 22;
    }

    .color-block--amber {
      --callout-color: 245 158 11;
    }

    .color-block--yellow {
      --callout-color: 234 179 8;
    }

    .color-block--lime {
      --callout-color: 132 204 22;
    }

    .color-block--green {
      --callout-color: 34 197 94;
    }

    .color-block--emerald {
      --callout-color: 16 185 129;
    }

    .color-block--teal {
      --callout-color: 20 184 166;
    }

    .color-block--cyan {
      --callout-color: 6 182 212;
    }

    .color-block--sky {
      --callout-color: 14 165 233;
    }

    .color-block--blue {
      --callout-color: 59 130 246;
    }

    .color-block--indigo {
      --callout-color: 99 102 241;
    }

    .color-block--violet {
      --callout-color: 139 92 246;
    }

    .color-block--purple {
      --callout-color: 168 85 247;
    }

    .color-block--fuchsia {
      --callout-color: 217 70 239;
    }

    .color-block--pink {
      --callout-color: 236 72 153;
    }

    .color-block--rose {
      --callout-color: 244 63 94;
    }

    .color-block--gray {
      --callout-color: 107 114 128;
    }

    :global(.dark) .color-block {
      background:
        linear-gradient(
          90deg,
          rgb(var(--callout-color) / 0.2),
          rgb(var(--callout-color) / 0.08)
        ),
        rgb(15 23 42 / 0.54);
      border-color: rgb(var(--callout-color) / 0.28);
    }

    pre {
      @apply m-0 overflow-visible rounded-lg;
      font-family: var(--font-code);
      line-height: 1.6;
    }

    pre[data-language='mermaid'] {
      @apply bg-transparent p-0 overflow-visible;
    }

    code {
      @apply block text-[15px];
      font-family: var(--font-code);
      letter-spacing: 0;
      line-height: 1.6;
    }

    :global(.article-prose .mermaid) {
      @apply max-h-[70vh] overflow-auto bg-white p-4 text-center dark:bg-neutral-900;
      --mermaid-background: #ffffff;
      cursor: zoom-in;
    }

    :global(.dark .article-prose .mermaid) {
      --mermaid-background: rgb(23 23 23);
    }

    :global(.article-prose .mermaid svg) {
      @apply mx-auto h-auto max-h-[calc(70vh-2rem)] max-w-full;
      background: var(--mermaid-background) !important;
      width: auto;
    }

    :global(.article-prose .mermaid svg .mermaid-background) {
      fill: var(--mermaid-background);
    }

    :global(.dark .article-prose .mermaid svg .actor),
    :global(.dark .article-prose .mermaid svg .labelBox),
    :global(.dark .article-prose .mermaid svg .node rect),
    :global(.dark .article-prose .mermaid svg .node polygon),
    :global(.dark .article-prose .mermaid svg .node circle),
    :global(.dark .article-prose .mermaid svg .node ellipse),
    :global(.dark .article-prose .mermaid svg .node path),
    :global(.dark .article-prose .mermaid svg .cluster rect) {
      fill: #262626 !important;
      stroke: #737373 !important;
    }

    :global(.dark .article-prose .mermaid svg .note),
    :global(.dark .article-prose .mermaid svg .loopLine),
    :global(.dark .article-prose .mermaid svg .labelBkg) {
      fill: #303030 !important;
      stroke: #737373 !important;
    }

    :global(.dark .article-prose .mermaid svg text),
    :global(.dark .article-prose .mermaid svg .label),
    :global(.dark .article-prose .mermaid svg .nodeLabel),
    :global(.dark .article-prose .mermaid svg .actor > tspan),
    :global(.dark .article-prose .mermaid svg .messageText),
    :global(.dark .article-prose .mermaid svg .loopText) {
      fill: #e5e5e5 !important;
      color: #e5e5e5 !important;
    }

    :global(.dark .article-prose .mermaid svg .actor-line),
    :global(.dark .article-prose .mermaid svg .messageLine0),
    :global(.dark .article-prose .mermaid svg .messageLine1),
    :global(.dark .article-prose .mermaid svg .flowchart-link),
    :global(.dark .article-prose .mermaid svg .edgePath path),
    :global(.dark .article-prose .mermaid svg .path) {
      stroke: #a3a3a3 !important;
    }

    .mermaid-panel {
      @apply my-5 md:my-6 overflow-hidden rounded-lg border border-neutral-200 bg-white dark:border-neutral-800 dark:bg-neutral-900;
    }

    .mermaid-toolbar {
      @apply flex items-center justify-between gap-3 border-b border-neutral-200 bg-neutral-50 px-2 py-1.5 dark:border-neutral-800 dark:bg-neutral-950/60;
    }

    .mermaid-toggle-group {
      @apply flex items-center gap-1;
    }

    .mermaid-toggle {
      @apply rounded-md px-2.5 py-1 text-xs font-medium text-neutral-500 transition-colors hover:bg-white hover:text-neutral-900 dark:text-neutral-400 dark:hover:bg-neutral-800 dark:hover:text-neutral-200;
    }

    .mermaid-toggle.is-active {
      @apply bg-white text-neutral-900 shadow-sm dark:bg-neutral-800 dark:text-neutral-200;
    }

    .mermaid-copy {
      @apply inline-flex h-8 w-8 shrink-0 items-center justify-center rounded-md border border-neutral-200 bg-white text-neutral-600 shadow-sm transition-colors hover:border-neutral-300 hover:bg-neutral-100 hover:text-neutral-950 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-300 dark:hover:border-neutral-700 dark:hover:bg-neutral-800 dark:hover:text-neutral-100 dark:focus-visible:ring-offset-neutral-950;
    }

    .mermaid-copy svg {
      @apply h-3.5 w-3.5;
    }

    :global(.article-prose .mermaid-code-view) {
      @apply relative m-0 min-w-0 max-w-full overflow-hidden rounded-none border-0 p-0;
      --scroll-area-track-inset-right: 0.5rem;
      --scroll-area-track-inset-left: 0.5rem;
      --scroll-area-track-inset-bottom: 0.25rem;
      max-height: 70vh;
    }

    :global(.article-prose .mermaid-code-block__scroll) {
      @apply relative m-0 min-w-0 max-w-full overflow-hidden rounded-none border-0 p-0 shadow-none;
      --code-block-bg: var(--shiki-light-bg, #ffffff);
      --code-block-border: transparent;
      --code-line-highlight-bg: rgb(243 244 246);
      --code-line-highlight-border: rgb(59 130 246);
      --code-word-bg: rgb(254 249 195);
      --code-gutter-bg: var(--code-block-bg);
      --code-gutter-border: rgb(226 232 240);
      --code-gutter-highlight-bg: var(--code-line-highlight-bg);
      --code-gutter-text: rgb(148 163 184);
      background-color: var(--code-block-bg);
      border-color: transparent;
      min-height: 0;
    }

    :global(.dark .article-prose .mermaid-code-block__scroll) {
      --code-block-bg: #111111;
      --code-block-border: #2a2a2a;
      --code-line-highlight-bg: rgb(31 41 55);
      --code-line-highlight-border: rgb(96 165 250);
      --code-word-bg: rgb(113 63 18);
      --code-gutter-bg: var(--code-block-bg);
      --code-gutter-border: #242424;
      --code-gutter-highlight-bg: var(--code-line-highlight-bg);
      --code-gutter-text: rgb(115 115 115);
      background-color: var(--code-block-bg);
    }

    :global(.article-prose .mermaid-code-block__viewport) {
      @apply w-full max-w-full overflow-x-auto overflow-y-hidden;
      min-height: 0;
      overscroll-behavior-x: contain;
      overscroll-behavior-y: auto;
      scrollbar-width: none;
      -ms-overflow-style: none;
      -webkit-overflow-scrolling: touch;
    }

    :global(.article-prose .mermaid-code-block__viewport::-webkit-scrollbar) {
      display: none;
      width: 0;
      height: 0;
    }

    :global(.article-prose .mermaid-code-block__content) {
      min-height: 0;
      width: max-content;
      min-width: 100%;
    }

    :global(.article-prose .mermaid-code-block__scrollbar) {
      position: absolute;
      right: var(--scroll-area-track-inset-right, 0.5rem);
      bottom: var(--scroll-area-track-inset-bottom, 0.25rem);
      left: var(--scroll-area-track-inset-left, 0.5rem);
      z-index: 10;
      height: var(--scroll-area-track-height, 0.375rem);
      border-radius: 999px;
      background: rgb(115 115 115 / 0.14);
      opacity: 0;
      pointer-events: none;
      transition: background-color 180ms ease;
    }

    :global(.article-prose .mermaid-code-block__scroll.scroll-area--scrollable .mermaid-code-block__scrollbar) {
      opacity: 1;
      pointer-events: auto;
    }

    :global(.article-prose .mermaid-code-block__thumb) {
      width: 0;
      height: 100%;
      min-width: 2rem;
      min-height: 0;
      border-radius: 999px;
      background: rgb(115 115 115 / 0.55);
      box-shadow: none;
      transition:
        background-color 180ms ease,
        transform 80ms linear;
    }

    :global(.article-prose .mermaid-code-block__scrollbar:hover),
    :global(.article-prose .mermaid-code-block__scroll.scroll-area--dragging .mermaid-code-block__scrollbar) {
      background: rgb(115 115 115 / 0.22);
    }

    :global(.article-prose .mermaid-code-block__scrollbar:hover .mermaid-code-block__thumb),
    :global(.article-prose .mermaid-code-block__scroll.scroll-area--dragging .mermaid-code-block__thumb) {
      background: rgb(82 82 82 / 0.72);
      box-shadow: none;
    }

    :global(.dark .article-prose .mermaid-code-block__thumb) {
      background: rgb(163 163 163 / 0.42);
      box-shadow: none;
    }

    :global(.dark .article-prose .mermaid-code-block__scrollbar:hover .mermaid-code-block__thumb),
    :global(.dark .article-prose .mermaid-code-block__scroll.scroll-area--dragging .mermaid-code-block__thumb) {
      background: rgb(212 212 212 / 0.56);
      box-shadow: none;
    }

    :global(.article-prose .mermaid-code-view pre) {
      @apply m-0 overflow-visible rounded-none border-0 bg-transparent p-0 shadow-none;
      --code-block-border: transparent;
      background-color: transparent !important;
      border: 0 !important;
      border-color: transparent !important;
      border-radius: 0 !important;
      box-shadow: none !important;
    }

    :global(.article-prose .mermaid-code-view pre > code) {
      @apply min-w-max py-0;
    }

    /* 行内代码样式 */
    :not(pre) > code {
      @apply text-[15px] bg-neutral-200 dark:bg-neutral-800 px-1.5 py-0.5 rounded-md text-neutral-900 dark:text-neutral-100 font-mono inline mx-0.5;
      font-family: var(--font-code);
      line-height: normal;
      &::before,
      &::after {
        content: none;
      }
    }

    :global(.dark) & :not(pre) > code {
      color: var(--article-dark-text);
    }

    .line-numbers-container {
      @apply text-gray-400 dark:text-gray-600 select-none h-full text-nowrap overflow-hidden;
    }

    .highlighted {
      background-color: var(--code-line-highlight-bg);
    }

    .word {
      @apply rounded px-1;
      background-color: var(--code-word-bg);
    }

    /* 表格样式 - 支持水平滚动 */
    table {
      @apply w-full border-collapse my-6;
      display: block;
      overflow-x: auto;
      -webkit-overflow-scrolling: touch;
    }

    thead {
      @apply bg-neutral-100 dark:bg-neutral-800;
    }

    th {
      @apply border border-neutral-300 px-4 py-2 text-left font-semibold text-neutral-900 dark:border-neutral-700 dark:text-neutral-100;
      white-space: nowrap;
    }

    td {
      @apply border border-neutral-300 px-4 py-2 text-neutral-700 dark:border-neutral-700 dark:text-neutral-300;
    }

    tbody tr:nth-child(even) {
      @apply bg-neutral-50 dark:bg-neutral-900/50;
    }

    tbody tr:hover {
      @apply bg-neutral-100 dark:bg-neutral-800/50;
    }
  }

  :global(.article-prose hr) {
    height: 0;
    margin: 2rem 0;
    border: 0 !important;
    border-top: 0 !important;
    background: transparent;
  }

  @media (min-width: 768px) {
    :global(.article-prose hr) {
      margin: 2.5rem 0;
    }
  }

  :global(.article-prose .code-block) {
    @apply relative my-5 max-w-full min-w-0 overflow-hidden rounded-lg border border-neutral-200 bg-neutral-50 md:my-6 dark:border-neutral-800 dark:bg-neutral-950;
    --scroll-area-track-inset-right: 0.5rem;
    --scroll-area-track-inset-left: 0.5rem;
    --scroll-area-track-inset-bottom: 0.25rem;
  }

  :global(.article-prose .code-block__language) {
    @apply absolute left-4 top-3 z-10 font-mono text-[11px] font-medium uppercase tracking-normal text-neutral-500 dark:text-neutral-500;
  }

  :global(.article-prose .code-block__copy) {
    @apply absolute right-3 top-2 z-10 inline-flex h-7 w-7 shrink-0 items-center justify-center rounded-md border border-neutral-200 bg-white/90 text-neutral-600 shadow-sm backdrop-blur transition-colors hover:border-neutral-300 hover:bg-neutral-100 hover:text-neutral-950 focus:outline-none focus-visible:ring-2 focus-visible:ring-primary-500 focus-visible:ring-offset-2 focus-visible:ring-offset-neutral-50 dark:border-neutral-700 dark:bg-neutral-900/90 dark:text-neutral-300 dark:hover:border-neutral-600 dark:hover:bg-neutral-800 dark:hover:text-neutral-100 dark:focus-visible:ring-offset-neutral-950;
  }

  :global(.article-prose .code-block__copy svg) {
    @apply h-3.5 w-3.5;
  }

  :global(.article-prose .code-block__scroll) {
    @apply relative max-w-full min-w-0 overflow-hidden rounded-lg border-0;
    --code-block-bg: #f8fafc;
    --code-block-border: transparent;
    --code-line-highlight-bg: rgb(241 245 249);
    --code-line-highlight-border: rgb(59 130 246);
    --code-word-bg: rgb(254 249 195);
    --code-gutter-bg: var(--code-block-bg);
    --code-gutter-border: rgb(226 232 240);
    --code-gutter-highlight-bg: var(--code-line-highlight-bg);
    --code-gutter-text: rgb(148 163 184);
    background-color: var(--code-block-bg);
    border-color: var(--code-block-border);
    min-height: 0;
  }

  :global(.dark .article-prose .code-block__scroll) {
    --code-block-bg: #111111;
    --code-block-border: #2a2a2a;
    --code-line-highlight-bg: rgb(31 41 55);
    --code-line-highlight-border: rgb(96 165 250);
    --code-word-bg: rgb(113 63 18);
    --code-gutter-bg: var(--code-block-bg);
    --code-gutter-border: #242424;
    --code-gutter-highlight-bg: var(--code-line-highlight-bg);
    --code-gutter-text: rgb(115 115 115);
    background-color: var(--code-block-bg);
  }

  :global(.article-prose .code-block__scroll .scroll-area__viewport) {
    @apply w-full max-w-full;
    min-height: 0;
    overflow-x: auto;
    overflow-y: hidden;
    overscroll-behavior-x: contain;
    overscroll-behavior-y: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
    -webkit-overflow-scrolling: touch;
  }

  :global(.article-prose .code-block__scroll .scroll-area__viewport::-webkit-scrollbar) {
    display: none;
    width: 0;
    height: 0;
  }

  :global(.article-prose .code-block__scroll .scroll-area__content) {
    @apply rounded-lg bg-slate-50;
    min-height: 0;
    width: max-content;
    min-width: 100%;
  }

  :global(.dark .article-prose .code-block__scroll .scroll-area__content) {
    @apply bg-[#111111];
  }

  :global(.article-prose .code-block__scroll .scroll-area__scrollbar) {
    position: absolute;
    right: var(--scroll-area-track-inset-right, 0.5rem);
    bottom: var(--scroll-area-track-inset-bottom, 0.25rem);
    left: var(--scroll-area-track-inset-left, 0.5rem);
    z-index: 10;
    height: var(--scroll-area-track-height, 0.375rem);
    border-radius: 999px;
    background: rgb(115 115 115 / 0.14);
    opacity: 0;
    pointer-events: none;
    transition: background-color 180ms ease;
  }

  :global(.article-prose .code-block__scroll.scroll-area--scrollable .scroll-area__scrollbar) {
    opacity: 1;
    pointer-events: auto;
  }

  :global(.article-prose .code-block__scroll .scroll-area__thumb) {
    width: 0;
    height: 100%;
    min-width: 2rem;
    min-height: 0;
    border-radius: 999px;
    background: rgb(115 115 115 / 0.55);
    box-shadow: none;
    transition:
