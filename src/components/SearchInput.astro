---
import Icon from './Icon.astro';

interface Props {
  placeholder?: string;
  value?: string;
  class?: string;
  live?: boolean;
}

const {
  placeholder = '搜索文章...',
  value = '',
  class: className = '',
  live = false,
} = Astro.props;
---

<div class={`relative w-full ${className}`}>
  <div class="relative">
    <input
      type="text"
      name="q"
      id="search-input"
      value={value}
      placeholder={placeholder}
      class="w-full pl-10 pr-4 py-2 rounded-md border border-gray-300 dark:border-gray-700 bg-white dark:bg-gray-800 text-gray-800 dark:text-gray-200 placeholder-gray-500 dark:placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary focus:border-transparent transition-all duration-300"
      autocomplete="off"
    />
    <div
      class="absolute inset-y-0 left-0 flex items-center pl-3 pointer-events-none"
    >
      <Icon name="search" class="text-gray-500 dark:text-gray-400" />
    </div>
    {
      value && (
        <button
          type="button"
          id="clear-search"
          class="absolute inset-y-0 right-0 flex items-center pr-3 text-gray-500 dark:text-gray-400 hover:text-gray-700 dark:hover:text-gray-200"
        >
          <span class="sr-only">清除搜索</span>
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="18"
            height="18"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      )
    }
  </div>

  <!-- 实时搜索结果容器 -->
  {
    live && (
      <div
        id="search-results"
        class="absolute z-10 w-full mt-1 bg-white dark:bg-gray-800 shadow-lg rounded-md border border-gray-200 dark:border-gray-700 overflow-hidden hidden"
      >
        <div class="p-2">
          <div
            id="search-loading"
            class="py-4 px-3 text-center text-gray-500 dark:text-gray-400 hidden"
          >
            <div class="inline-block animate-spin mr-2">
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
              >
                <path d="M21 12a9 9 0 1 1-6.219-8.56" />
              </svg>
            </div>
            正在搜索...
          </div>
          <div id="search-list" />
          <div
            id="search-empty"
            class="py-4 px-3 text-center text-gray-500 dark:text-gray-400 hidden"
          >
            没有找到匹配的结果
          </div>
        </div>
        <div class="border-t border-gray-200 dark:border-gray-700 p-2 text-xs text-gray-500 dark:text-gray-400 text-center">
          按回车键查看所有结果
        </div>
      </div>
    )
  }
</div>

<script>
  // 获取搜索输入框
  const searchInput = document.getElementById(
    'search-input'
  ) as HTMLInputElement;
  const clearButton = document.getElementById('clear-search');
  const form = searchInput?.closest('form');

  // 清除按钮功能
  clearButton?.addEventListener('click', () => {
    if (searchInput) {
      searchInput.value = '';
      searchInput.focus();

      // 如果在搜索页，提交表单以清除搜索
      if (window.location.pathname === '/search' && form) {
        form.submit();
      }
    }
  });

  // 监听按键事件
  searchInput?.addEventListener('keydown', e => {
    if (e.key === 'Enter' && form) {
      form.submit();
    }
  });
</script>
