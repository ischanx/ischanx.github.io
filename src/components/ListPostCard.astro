---
import type { CollectionEntry } from 'astro:content';
import { getPostUrl } from '../utils/route';
import { createTagUrl } from '../utils/navigation';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
---

<div
  class="flex flex-col md:flex-row rounded-lg overflow-hidden border border-gray-200 dark:border-gray-700 shadow-sm hover:shadow-md transition-shadow"
>
  <div
    class="md:w-1/4 h-48 md:h-auto bg-gray-200 dark:bg-gray-700 flex items-center justify-center"
  >
    {
      post.data.image ? (
        <img
          src={post.data.image}
          alt={post.data.title}
          class="w-full h-full object-cover"
        />
      ) : (
        <div class="text-gray-400 dark:text-gray-500">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="48"
            height="48"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
          >
            <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
            <circle cx="8.5" cy="8.5" r="1.5" />
            <path d="m21 15-5-5L5 21" />
          </svg>
        </div>
      )
    }
  </div>
  <div class="md:w-3/4 p-6">
    <h3 class="text-2xl font-bold mb-2">
      <a href={getPostUrl(post)} class="hover:text-blue-600 transition-colors">
        {post.data.title}
      </a>
    </h3>
    <p class="text-gray-600 dark:text-gray-400 mb-4">
      {post.data.description || ''}
    </p>
    <div class="flex flex-wrap gap-2">
      {
        post.data.tags?.map((tag: string) => (
          <a
            href={createTagUrl(tag)}
            data-target-tag={tag}
            class="text-sm px-3 py-1 rounded-full bg-gray-200 dark:bg-gray-700 text-gray-700 dark:text-gray-300 hover:bg-blue-100 dark:hover:bg-blue-900 hover:text-blue-600 dark:hover:text-blue-300 transition-colors"
          >
            {tag}
          </a>
        ))
      }
    </div>
  </div>
</div>
