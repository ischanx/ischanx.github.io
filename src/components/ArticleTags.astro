---
import { createTagUrl } from '../utils/navigation';

interface Props {
  tags?: string[];
}

const { tags } = Astro.props;
---

<div
  class="flex flex-wrap items-center gap-x-3 gap-y-1.5 text-[13px] leading-6 text-gray-500 dark:text-gray-400 animate-slide-up"
>
  {
    tags && tags.length > 0 && (
      <div
        class="flex flex-wrap gap-1.5 md:gap-2 animate-slide-up"
        style="animation-delay: 200ms;"
      >
        {tags.map((tag: string) => (
          <a
            href={createTagUrl(tag)}
            class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors duration-200"
          >
            #{tag}
          </a>
        ))}
      </div>
    )
  }
</div>
