---
import {
  ArrowLeft,
  ArrowRight,
  Calendar,
  Clock3,
  Copy,
  FileText,
  Grid2x2,
  Home,
  Link,
  Mail,
  Moon,
  Pencil,
  Pin,
  Rss,
  Search,
  Sun,
  Tag,
  Tags,
  User,
} from 'lucide-react';

interface Props {
  name: string;
  class?: string;
  fontSize?: string;
}

const { name, class: className, fontSize } = Astro.props as Props;

const brandIcons: Record<string, string> = {
  github: `
    <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M12 .5C5.649.5.5 5.649.5 12a11.5 11.5 0 0 0 7.863 10.911c.575.106.787-.25.787-.556 0-.275-.012-1.187-.018-2.15-3.2.694-3.877-1.357-3.877-1.357-.524-1.332-1.28-1.686-1.28-1.686-1.046-.715.08-.7.08-.7 1.156.081 1.765 1.187 1.765 1.187 1.028 1.762 2.697 1.252 3.354.957.103-.744.402-1.252.731-1.54-2.554-.29-5.238-1.277-5.238-5.684 0-1.256.449-2.282 1.184-3.087-.119-.29-.513-1.458.112-3.04 0 0 .966-.309 3.166 1.179a10.98 10.98 0 0 1 5.764 0c2.198-1.488 3.162-1.18 3.162-1.18.627 1.583.233 2.751.114 3.041.737.805 1.182 1.831 1.182 3.087 0 4.418-2.689 5.39-5.25 5.675.413.355.78 1.052.78 2.12 0 1.531-.014 2.764-.014 3.14 0 .309.207.668.793.555A11.502 11.502 0 0 0 23.5 12C23.5 5.649 18.351.5 12 .5Z"/>
    </svg>
  `,
  twitter: `
    <svg xmlns="http://www.w3.org/2000/svg" width="1em" height="1em" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
      <path d="M18.244 2H21.5l-7.11 8.128L22.75 22h-6.547l-5.126-6.71L5.21 22H1.95l7.605-8.695L1.5 2H8.21l4.634 6.116L18.244 2Zm-1.143 18h1.804L7.23 3.895H5.294L17.1 20Z"/>
    </svg>
  `,
};

const icons = {
  'arrow-left': ArrowLeft,
  'arrow-right': ArrowRight,
  calendar: Calendar,
  category: Tag,
  clock: Clock3,
  copy: Copy,
  edit: Pencil,
  'file-text': FileText,
  grid: Grid2x2,
  home: Home,
  link: Link,
  mail: Mail,
  moon: Moon,
  pin: Pin,
  rss: Rss,
  search: Search,
  sun: Sun,
  tags: Tags,
  user: User,
} as const;

const LucideIcon = icons[name as keyof typeof icons];
const brandIcon = brandIcons[name];
const size = fontSize ?? '1em';
const style = `font-size: ${size};`;
---

{
  brandIcon ? (
    <span class={className} style={style} set:html={brandIcon} />
  ) : LucideIcon ? (
    <LucideIcon className={className} size={size} aria-hidden="true" />
  ) : null
}
